{
	"editor.unicodeHighlight.nonBasicASCII": false,
	"breadcrumbs.filePath": "off",
	"remote.SSH.remotePlatform": {
		"aliyun-hk-wkyuu": "linux",
		"aliyun-wkyuu": "linux"
	},
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"notebook.lineNumbers": "on",
	"security.workspace.trust.untrustedFiles": "open",
	"explorer.confirmDragAndDrop": false,
	"liveServer.settings.donotShowInfoMsg": true,
	"window.commandCenter": false,
	"terminal.integrated.defaultProfile.linux": "zsh",
	"workbench.iconTheme": "material-icon-theme",
	"http.proxyStrictSSL": false,
	"remote.SSH.localServerDownload": "always",
	"update.showReleaseNotes": false,
	"extensions.autoUpdate": false,
	"extensions.autoCheckUpdates": false,
	"editor.stickyScroll.enabled": false,
	"window.confirmSaveUntitledWorkspace": false,
	"[nginx]": {
		"editor.defaultFormatter": "ahmadalli.vscode-nginx-conf"
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[yaml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[javascript]": {
		"editor.defaultFormatter": "vscode.typescript-language-features"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	"editor.accessibilitySupport": "off",
	"editor.fontFamily": "'MonoLisa-Medium', '文泉驿等宽微米黑'",
	"nginx-conf-hint.format.align": true,
	"window.titleBarStyle": "native",
	"editor.find.addExtraSpaceOnTop": false,
	"terminal.explorerKind": "external",
	"breadcrumbs.icons": false,
	"breadcrumbs.enabled": false,
	"cursor.cpp.disabledLanguages": [
		"plaintext",
		"csv (pipe)"
	],
	"workbench.activityBar.orientation": "vertical",
	"python.createEnvironment.trigger": "off",
	"editor.minimap.renderCharacters": false,
	"terminal.integrated.profiles.linux": {
		"bash": {
			"path": "bash",
			"icon": "terminal-bash"
		},
		"tmux": {
			"path": "tmux",
			"icon": "terminal-tmux"
		}
	},
	"terminal.external.linuxExec": "bash",
	"[dockerfile]": {
		"editor.defaultFormatter": "ms-azuretools.vscode-docker"
	},
	"git.openRepositoryInParentFolders": "never",
	"editor.minimap.enabled": true,
	"editor.insertSpaces": false,
	"cursorpyright.analysis.disableWorkspaceSymbol": true,
	"files.associations": {
		"*.pmt": "markdown",
		"*.tldr": "toml"
	},
	"terminal.integrated.initialHint": false,
	"workbench.editor.empty.hint": "hidden",
	"terminal.integrated.stickyScroll.enabled": false,
	"workbench.startupEditor": "none",
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"search.followSymlinks": false,
	"chat.extensionUnification.enabled": false,
	"remote.SSH.experimental.chat": false,
	"dev.containers.dockerComposePath": "docker compose",
	"docker.enableDockerComposeLanguageService": false,
	"claudeCode.preferredLocation": "panel",
	"workbench.editor.editorActionsLocation": "titleBar",
	"containers.enableComposeLanguageService": false,
	"terminal.integrated.initialHint.copilotCli": false,
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff"
	},
	"extensions.ignoreRecommendations": true,
	"workbench.layoutControl.enabled": false,
	"chat.viewSessions.orientation": "stacked",
	"github.copilot.chat.backgroundAgent.enabled": false,
	"github.copilot.chat.localeOverride": "zh-CN",
	"files.watcherExclude": {
		"**/archive/**": true,
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/__pycache__/**": true,
		"**/node_modules/**": true,
		"**/.venv/**": true,
		"**/venv/**": true
	},
	"search.exclude": {
		"**/archive/**": true,
		"**/__pycache__/**": true,
		"**/node_modules/**": true,
		"**/.venv/**": true,
		"**/venv/**": true
	},
	"files.exclude": {
		"**/archive": true,
		"**/__pycache__": true
	},
	"github.copilot.chat.claudeAgent.enabled": false,
	"github.copilot.chat.cloudAgent.enabled": false,
	"github.copilot.chat.organizationInstructions.enabled": false,
	"github.copilot.chat.reviewAgent.enabled": false,
	"github.copilot.chat.organizationCustomAgents.enabled": false,
	"github.copilot.chat.reviewSelection.enabled": false,
	"github.copilot.chat.copilotDebugCommand.enabled": false,
	"workbench.browser.enableChatTools": false,
	"workbench.commandPalette.showAskInChat": false,
	"chat.agent.enabled": false,
	"chat.disableAIFeatures": true
}